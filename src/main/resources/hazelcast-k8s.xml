<?xml version="1.0" encoding="UTF-8"?>
<!--
  Hazelcast cluster config for Kubernetes - DNS Lookup mode.
  Pods discover each other by resolving the headless Service DNS name,
  which Kubernetes automatically resolves to the IPs of all matching pods.
  No RBAC / ServiceAccount permissions required for this mode.

  Required Service (headless ClusterIP):
    - clusterIP: None
    - selector matching your pod labels
    - port 5701
  The service-dns below can be the short headless Service name when pods run
  in the same namespace as the Service.
-->
<hazelcast xmlns="http://www.hazelcast.com/schema/config"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="http://www.hazelcast.com/schema/config
           https://hazelcast.com/schema/config/hazelcast-config-5.3.xsd">

    <cluster-name>onecx-notification-cluster</cluster-name>

    <network>
        <port auto-increment="false">5701</port>
        <join>
            <auto-detection enabled="false"/>
            <multicast enabled="false"/>
            <tcp-ip enabled="false"/>
            <kubernetes enabled="true">
                <service-dns>onecx-notification-bff-hazelcast</service-dns>
                <service-port>5701</service-port>
            </kubernetes>
        </join>
        <interfaces enabled="false"/>
    </network>

    <map name="notifications">
        <!-- keep notifications for 1 hour max; evict LRU when heap is full -->
        <time-to-live-seconds>3600</time-to-live-seconds>
        <max-idle-seconds>3600</max-idle-seconds>
        <eviction eviction-policy="LRU" max-size-policy="FREE_HEAP_PERCENTAGE" size="20"/>
        <!-- sync backups: 1 (survives loss of 1 pod) -->
        <backup-count>1</backup-count>
        <async-backup-count>0</async-backup-count>
    </map>

</hazelcast>
